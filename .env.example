# NVIDIA Build API (OpenAI-compatible) — used by every stage
NVIDIA_API_KEY=nvapi-...
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Default models (override per stage in configs/ if needed)
NEMOTRON_MODEL=nvidia/nemotron-3-nano-30b-a3b
NEMOTRON_JUDGE_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NEMOTRON_SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety
NEMOTRON_REWARD_MODEL=nvidia/nemotron-4-340b-reward
RETRIEVER_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# Stage 1 web fallback
TAVILY_API_KEY=tvly-...

# Optional: switch stage 1 cultural mapper to the NeMo Agent Toolkit ReAct workflow
MAP_REFS_USE_NAT=0
